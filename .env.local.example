# --- Supabase (requerido en runtime) ---
# El URL y el anon key también están hardcoded en src/lib/supabase-env.ts
# como fallback, pero se recomienda definirlos aquí para poder rotar sin tocar código.
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url-here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# --- Miro (solo servidor) ---
# Usado por /api/tasks para leer el doc histórico en Miro.
# NO uses el prefijo NEXT_PUBLIC_ porque este token NO debe llegar al bundle del cliente.
MIRO_ACCESS_TOKEN=your-miro-access-token-here

# --- Embed ---
# Shared secret para autorizar las URLs públicas de /embed/[clientId]/plan?token=...
# Generar con: `openssl rand -hex 24` o similar. Rotar si se filtra.
EMBED_SECRET=generate-a-random-string-here

# --- Acumulado de ventas por cliente (server-only) ---
# Mapa de clientId → ventas acumuladas del año en curso.
# Leído por /api/clients/accumulated-sales (requiere sesión).
# Se muestra como footnote en la tarjeta de "ventas" del tab Indicadores.
# Formato: JSON con strings o números como valor. Claves que no estén aquí
# devuelven null (no se muestra footnote).
# Ejemplo:
# CLIENT_ACCUMULATED_SALES_JSON={"client-cygnuss":0,"client-dentilandia":0,"client-acautos":0}
CLIENT_ACCUMULATED_SALES_JSON={}

# --- Procesar facturas (Gmail → Drive → Sheets) ---
# Setup paso a paso: ver docs/PROCESAR-FACTURAS.md
# Necesitas crear un OAuth client en Google Cloud Console (tipo "Desktop")
# y luego correr: node --env-file=.env.local scripts/setup-oauth.mjs
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=
# ID de la carpeta de Drive donde van los ZIP/PDF/XML (sacarlo del URL del folder)
INVOICES_DRIVE_FOLDER_ID=1ksS7gwlT8OYmMh4Eh2WiIQGNwkERdti2
# ID del Google Sheets de control (sacarlo del URL)
INVOICES_SHEET_ID=1dwCu-1ooeyOC5PEd2lBIhua4zUmC5ymymQ6X0O4zcMU
# Pestaña dentro del Sheets (default: Gastos)
INVOICES_SHEET_TAB=Gastos
